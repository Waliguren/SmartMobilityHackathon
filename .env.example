# Shared
APP_ENV=development

# Backend API
API_HOST=0.0.0.0
API_PORT=8000
API_CORS_ORIGINS=http://localhost:5173,http://localhost:3000
DATABASE_URL=postgresql+psycopg://smartmobility:smartmobility@localhost:5432/smartmobility
DATABASE_AUTO_CREATE=true
DATABASE_ECHO=false

# Planning
PLANNING_DEFAULT_DAILY_CAPACITY_MINUTES=480
PLANNING_MAX_ASSIGNMENT_RADIUS_KM=180
PLANNING_AVERAGE_SPEED_KPH=60
ROAD_GRAPH_GEOJSON_PATH=

# Firebase
FIREBASE_PROJECT_ID=your-project-id
FIREBASE_CLIENT_EMAIL=firebase-adminsdk@example.iam.gserviceaccount.com
FIREBASE_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\nYOUR_KEY\n-----END PRIVATE KEY-----\n"
FIREBASE_STORAGE_BUCKET=your-project-id.appspot.com

# OpenChargeMap
OPENCHARGEMAP_API_KEY=
OPENCHARGEMAP_BASE_URL=https://api.openchargemap.io/v3

# Google Fleet Routing
GOOGLE_CLOUD_PROJECT_ID=
GOOGLE_CLOUD_LOCATION=global
GOOGLE_SERVICE_ACCOUNT_FILE=
GOOGLE_SERVICE_ACCOUNT_JSON=
GOOGLE_FLEET_ROUTING_ENABLED=false

# Web gestores
VITE_API_BASE_URL=http://localhost:8000

# Mobile
FLUTTER_API_BASE_URL=http://10.0.2.2:8000